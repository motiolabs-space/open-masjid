#--------------------------------------------------------------------
# PENYIMPANAN BERKAS (foto galeri, logo, QRIS, bukti transaksi)
#--------------------------------------------------------------------
# STORAGE_DRIVER = 'local'   # 'local' atau 's3'
#
# STORAGE_PATH — folder tempat berkas ditulis ke disk. Dipakai oleh driver
# 'local', DAN sebagai cadangan bila unggahan ke S3 gagal (lihat di bawah).
# Bawaan: FCPATH, yaitu root proyek tempat index.php berada.
#
# DISARANKAN: arahkan ke SUBFOLDER di dalam root web, bukan ke root web itu
# sendiri. Pola penyimpanannya {username}/{tahun}/{bulan}/..., sehingga bila
# STORAGE_PATH = root web, akan terbentuk direktori nyata bernama username
# masjid tepat di root. Direktori itu menutupi rute profil publik '(:any)':
# permintaan /qamar tidak lagi sampai ke router, mod_dir menambah trailing
# slash (301), dan berakhir 403 karena Options -Indexes — halaman profil masjid
# tersebut rusak. Ini pernah benar-benar terjadi. 'DirectorySlash Off' pada
# .htaccess root sudah menambalnya, tetapi memakai subfolder menutup akarnya.
#
#   STORAGE_PATH = '/home/customer/www/masj.id/public_html/uploads'
#   STORAGE_URL  = 'https://masj.id/uploads'
#
# Jangan mengarahkannya ke LUAR root web kecuali menyiapkan route penyaji
# berkas: berkas cadangan tidak akan dapat diakses dan gambarnya rusak.
#
# Mengubah nilai ini tidak memengaruhi berkas lama — path pada basis data tetap
# apa adanya, dan S3 tetap sumber utamanya.
# STORAGE_PATH = ''
#
# STORAGE_URL — alamat web yang memetakan STORAGE_PATH. Isi bila STORAGE_PATH
# BUKAN root web. Bila dikosongkan, dipakai base_url(), yang sudah tepat untuk
# STORAGE_PATH = root web.
# Catatan: asset_url() sengaja TIDAK dipakai untuk berkas unggahan, karena
# helper itu menambahkan awalan 'public/' yang hanya benar untuk aset statis.
# STORAGE_URL = ''
#
# CADANGAN OTOMATIS
# Bila STORAGE_DRIVER = 's3' dan unggahan ke S3 gagal (mis. S3 sedang padam),
# berkas TIDAK dibuang: ia disimpan ke STORAGE_PATH lalu dicatat ke log sebagai
# peringatan. Storage::url() mengutamakan berkas yang ada di disk, sehingga
# gambarnya tetap tampil. Setelah S3 pulih, berkas cadangan itu tersalin
# otomatis pada deploy berikutnya lewat migrasi MigrateFilesToS3.
#
# Karena url() mengutamakan berkas di disk, selama salinan lama masih ada di
# STORAGE_PATH, gambar disajikan dari server sendiri — bukan dari S3. Hapus
# salinan lokal itu setelah yakin semuanya sudah tersalin ke S3 bila ingin
# seluruh gambar dilayani S3.
#
#--------------------------------------------------------------------
# S3 / DigitalOcean Spaces  (dipakai bila STORAGE_DRIVER = 's3')
#--------------------------------------------------------------------
# PENTING — S3_ENDPOINT harus endpoint REGION, BUKAN endpoint bucket.
# AWS SDK menambahkan nama bucket di depan host endpoint (virtual-host style),
# sehingga endpoint bucket membuat nama bucket tertulis DUA KALI:
#
#   SALAH : S3_ENDPOINT = 'https://cdn-masjid.sgp1.digitaloceanspaces.com'
#           -> URL jadi https://cdn-masjid.cdn-masjid.sgp1.digitaloceanspaces.com/...
#           -> host bertingkat dua TIDAK tercakup sertifikat wildcard DO
#              (*.sgp1.digitaloceanspaces.com hanya cocok satu tingkat),
#              sehingga TLS gagal: gambar diblokir browser DAN upload gagal.
#
#   BENAR : S3_ENDPOINT = 'https://sgp1.digitaloceanspaces.com'
#           -> URL jadi https://cdn-masjid.sgp1.digitaloceanspaces.com/...
#
# S3_REGION sebaiknya memakai kode region DigitalOcean (sgp1, nyc3, ...) agar
# jelas, meskipun DigitalOcean tidak memvalidasinya saat menandatangani
# permintaan — nilai seperti 'ap-southeast-1' pun tetap diterima. Yang WAJIB
# benar adalah S3_ENDPOINT di atas.
#
# Contoh untuk DigitalOcean Spaces (Singapura):
# STORAGE_DRIVER = 's3'
# S3_REGION      = 'sgp1'
# S3_BUCKET      = 'cdn-masjid'
# S3_ENDPOINT    = 'https://sgp1.digitaloceanspaces.com'
# S3_KEY         = ''
# S3_SECRET      = ''
#
# Opsional. Bila diisi, URL publik dibentuk langsung dari nilai ini dan
# getObjectUrl() dilewati — berguna bila memakai CDN atau domain sendiri.
# S3_PUBLIC_URL = 'https://cdn-masjid.sgp1.digitaloceanspaces.com'
# atau lewat CDN DigitalOcean:
# S3_PUBLIC_URL = 'https://cdn-masjid.sgp1.cdn.digitaloceanspaces.com'
#
# Setel 'true' hanya untuk S3-compatible yang memerlukan path-style
# (mis. MinIO). DigitalOcean Spaces tidak memerlukannya.
# S3_USE_PATH_STYLE = false
