# Disable directory browsing
Options -Indexes

# Berkas unggahan disimpan ke root proyek dengan pola {username}/{tahun}/...,
# sehingga sekali sebuah masjid mengunggah foto terbentuk direktori nyata
# bernama sama dengan username-nya. Tanpa baris ini, mod_dir mengalihkan
# /qamar -> /qamar/ (301) dan permintaan berakhir 403 karena Options -Indexes,
# membuat halaman profil publik masjid tersebut rusak permanen.
# Aman: penjelajahan direktori sudah dimatikan oleh Options -Indexes di atas.
<IfModule mod_dir.c>
    DirectorySlash Off
</IfModule>

# ----------------------------------------------------------------------
# Blokir berkas sensitif & skrip pengembangan
# ----------------------------------------------------------------------
# PENTING: docroot proyek ini adalah root (index.php ada di sini), dan aturan
# "RewriteCond %{REQUEST_FILENAME} !-f" di bawah menyajikan berkas yang ADA
# secara apa adanya tanpa lewat router. Tanpa blok ini, berkas seperti
# github_deploy_key, *.sql, atau .env bisa diunduh siapa saja.

# Kunci, rahasia, dump database, log
<FilesMatch "(?i)(^\.env|^\.env\.|_key$|_key\.pub$|\.pem$|\.ppk$|\.sql$|\.log$|^composer\.(json|lock)$)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Skrip debug/uji/seeder (mis. public/check_db.php, public/seed_regencies_smart.php).
# Semuanya bergaya CLI dan tetap bisa dijalankan lewat terminal:
#   php public/check_db.php
# Yang diblokir hanya akses lewat HTTP, karena seeder dapat menulis ke database
# tanpa autentikasi bila dipanggil dari browser.
<FilesMatch "(?i)^(analyze|check|debug|fetch|seed|test)_.*\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ----------------------------------------------------------------------
# Rewrite engine
# ----------------------------------------------------------------------

# Turning on the rewrite engine is necessary for the following rules and features.
# FollowSymLinks must be enabled for this to work.
<IfModule mod_rewrite.c>
	Options +FollowSymlinks
	RewriteEngine On

	# If you installed CodeIgniter in a subfolder, you will need to
	# change the following line to match the subfolder you need.
	# http://httpd.apache.org/docs/current/mod/mod_rewrite.html#rewritebase
	# RewriteBase /

	# Redirect Trailing Slashes...
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteCond %{REQUEST_URI} (.+)/$
	RewriteRule ^ %1 [L,R=301]

	# Rewrite "www.example.com -> example.com"
	RewriteCond %{HTTPS} !=on
	RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
	RewriteRule ^ http://%1%{REQUEST_URI} [R=301,L]

	# Checks to see if the user is attempting to access a valid file,
	# such as an image or css document, if this isn't true it sends the
	# request to the front controller, index.php
	#
	# PENTING: sengaja TIDAK memakai "RewriteCond %{REQUEST_FILENAME} !-d".
	# Berkas unggahan disimpan ke FCPATH (root proyek) dengan pola
	# {username}/{tahun}/{bulan}/..., sehingga sekali sebuah masjid mengunggah
	# foto, terbentuk DIREKTORI NYATA bernama sama dengan username-nya di root.
	# Dengan kondisi !-d, direktori itu menutupi rute profil publik '(:any)':
	# permintaan /qamar tidak lagi diteruskan ke index.php, lalu mod_dir
	# menambahkan trailing slash (301) dan berakhir 403 karena Options -Indexes.
	# Akibatnya halaman profil masjid tersebut rusak permanen.
	#
	# Tanpa !-d, permintaan yang bukan BERKAS nyata selalu diteruskan ke router;
	# berkas unggahan tetap tersaji langsung karena tertangkap oleh !-f.
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^([\s\S]*)$ index.php?/$1 [L,NC,QSA]

	# Ensure Authorization header is passed along
	RewriteCond %{HTTP:Authorization} .
	RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

<IfModule !mod_rewrite.c>
	# If we don't have mod_rewrite installed, all 404's
	# can be sent to index.php, and everything works as normal.
	ErrorDocument 404 index.php
</IfModule>

# Disable server signature start
ServerSignature Off
# Disable server signature end
